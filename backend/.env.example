# Hugging Face Open-Weight Models
# Option A: HF Inference API (no GPU needed — uses Hugging Face cloud)
# Option B: Local vLLM / LMDeploy servers (requires NVIDIA GPU)

## Variant Generator (Qwen 14B)
# HF cloud:  LLM_VARIANT_BASE_URL=https://router.hugging-face.cn/v1
# Local vLLM: LLM_VARIANT_BASE_URL=http://localhost:8001/v1
LLM_VARIANT_BASE_URL=https://router.huggingface.co/hf-inference/v1
LLM_VARIANT_MODEL_ID=Qwen/Qwen2.5-72B-Instruct

# Chatbot Options
LLM_CHAT_BASE_URL=https://router.huggingface.co/hf-inference/v1
LLM_CHAT_MODEL_ID=Qwen/Qwen2.5-7B-Instruct

# TextGuard QA Vision Options
VLM_QA_BASE_URL=https://router.huggingface.co/hf-inference/v1
VLM_QA_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct

## TextGuard QA Verdicts (InternVL2 8B)
VLM_QA_BASE_URL=https://router.hugging-face.cn/v1
VLM_QA_MODEL_ID=OpenGVLab/InternVL2-8B

# Auth: set to your HF token for cloud, or "dummy" for local servers
OPENAI_COMPAT_API_KEY=hf_your_token_here
MODEL_TIMEOUT_SECONDS=120
MODEL_TEMPERATURE=0.2
MODEL_MAX_TOKENS=2048

# Orchestrator & Integrations
OCR_PROVIDER=easyocr
USE_CREWAI=false
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── Wan2.1 Video Generation (Optional — requires CUDA GPU) ──
ENABLE_VIDEO_GEN=false
AUTO_VIDEO_GEN=false
VIDEO_GEN_PROVIDER=wan21
WAN21_MODEL_ID=Wan-AI/Wan2.1-T2V-1.3B-Diffusers
WAN21_DEVICE=cuda
WAN21_WIDTH=832
WAN21_HEIGHT=480
WAN21_NUM_FRAMES=81
WAN21_FPS=15
WAN21_GUIDANCE_SCALE=5.0
WAN21_SEED=42
WAN21_TORCH_DTYPE=bfloat16
# WAN21_NEGATIVE_PROMPT="Bright tones, overexposed, static, blurry details, ..."

# Backend Config
CORS_ORIGINS=http://localhost:3000
